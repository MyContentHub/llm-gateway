{
  "name": "llm-gateway",
  "version": "0.1.0",
  "description": "LLM API security proxy gateway — intercepts, scans, and audits all OpenAI-compatible API requests",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "clean": "rimraf dist",
    "gen-key": "node -e \"console.log(require('crypto').randomBytes(16).toString('hex'))\"",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "llm",
    "proxy",
    "gateway",
    "openai",
    "security"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.18.3",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.8.0",
    "compromise": "^14.15.0",
    "eventsource-parser": "^3.0.6",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "js-tiktoken": "^1.0.21",
    "prom-client": "^15.1.3",
    "smol-toml": "^1.6.1",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "better-sqlite3",
      "esbuild"
    ]
  }
}
