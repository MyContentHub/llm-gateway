# Server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Providers (JSON array of provider configs)
# Each provider: { "name": "openai", "baseUrl": "https://api.openai.com/v1", "apiKey": "sk-..." }
PROVIDERS=[]

# Database
DATABASE_PATH=./data/gateway.db

# Encryption key for storing upstream API keys (32 hex chars = 128-bit)
ENCRYPTION_KEY=

# Rate limits
DEFAULT_RPM=60
DEFAULT_TPM=100000
