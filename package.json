{
  "name": "llm-gateway",
  "version": "0.1.0",
  "description": "LLM API security proxy gateway — intercepts, scans, and audits all OpenAI-compatible API requests",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "clean": "rimraf dist"
  },
  "keywords": [
    "llm",
    "proxy",
    "gateway",
    "openai",
    "security"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.18.3",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "eventsource-parser": "^3.0.6",
    "fastify": "^5.8.4",
    "smol-toml": "^1.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
