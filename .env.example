# Server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Providers (JSON array of provider configs)
# Each provider requires: name, baseUrl, apiKey
# Optional: modelMappings (alias -> real model name), isDefault
# Example:
# PROVIDERS=[
#   {
#     "name": "openai",
#     "baseUrl": "https://api.openai.com/v1",
#     "apiKey": "sk-...",
#     "isDefault": true,
#     "modelMappings": {
#       "gpt4": "gpt-4o",
#       "gpt4-mini": "gpt-4o-mini"
#     }
#   },
#   {
#     "name": "deepseek",
#     "baseUrl": "https://api.deepseek.com/v1",
#     "apiKey": "sk-...",
#     "modelMappings": {
#       "reasoner": "deepseek-reasoner"
#     }
#   }
# ]
PROVIDERS=[]

# Database
DATABASE_PATH=./data/gateway.db

# Encryption key for storing upstream API keys (32 hex chars = 128-bit)
ENCRYPTION_KEY=

# Rate limits (defaults)
DEFAULT_RPM=60
DEFAULT_TPM=100000
